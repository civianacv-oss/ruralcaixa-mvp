+            dados.comprador, dados.nota_fiscal, dados.observacoes,
+        )
+        conn.commit()
+        return resultado
+    except HTTPException:
+        raise
+    except Exception as e:
+        conn.rollback()
+        raise HTTPException(status_code=500, detail=str(e))
