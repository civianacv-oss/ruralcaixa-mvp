+        INSERT INTO cv_compras
+            (imovel_id, produto_id, data_compra, quantidade, valor_unitario,
+             valor_total, regime, fornecedor, observacoes)
+        VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s)
+        RETURNING id
