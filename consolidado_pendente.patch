+        return existente["id"]
+
+    cur.execute("""
+        INSERT INTO cv_produtos (imovel_id, nome, unidade, especie)
+        VALUES (%s, %s, 'cab', %s) RETURNING id
+    """, (imovel_id, especie.capitalize(), especie))
+    return cur.fetchone()["id"]
